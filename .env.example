# ── Supabase ──────────────────────────────────────────────────────────────────
# Create a project at supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Claude / HOPE Companion ────────────────────────────────────────────────────
# Get your key at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Nakama (MMO backend: accounts, matchmaking, chat, leaderboards) ────────────
# Self-host via Docker: https://heroiclabs.com/docs/nakama/getting-started/install/docker/
NEXT_PUBLIC_NAKAMA_HOST=127.0.0.1
NEXT_PUBLIC_NAKAMA_PORT=7350
NEXT_PUBLIC_NAKAMA_SERVER_KEY=defaultkey
NEXT_PUBLIC_NAKAMA_SSL=false

# ── PostHog (behavioral analytics) ────────────────────────────────────────────
# Get your key at posthog.com → Project Settings → API Keys
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── LiveKit (voice & video social rooms) ──────────────────────────────────────
# Cloud: https://cloud.livekit.io  |  Self-host: https://docs.livekit.io/home/self-hosting/
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# ── Matrix / Synapse (federated chat & community messaging) ───────────────────
# Self-host: https://element-hq.github.io/synapse/latest/setup/installation.html
NEXT_PUBLIC_MATRIX_HOMESERVER_URL=https://matrix.your-domain.com

# ── Vercel (auto-injected on deploy, set via Dashboard or CLI) ─────────────────
# vercel env add NEXT_PUBLIC_SUPABASE_URL
# vercel env add NEXT_PUBLIC_SUPABASE_ANON_KEY
# vercel env add ANTHROPIC_API_KEY
# vercel env add NEXT_PUBLIC_NAKAMA_HOST
# vercel env add NEXT_PUBLIC_POSTHOG_KEY
# vercel env add NEXT_PUBLIC_LIVEKIT_URL
# vercel env add NEXT_PUBLIC_MATRIX_HOMESERVER_URL
